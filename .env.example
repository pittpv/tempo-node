# Tempo Node Installer — config (copy to .env-tempo and edit)
# Load order: ./install-tempo.sh loads SCRIPT_DIR/.env-tempo then TEMPO_HOME/.env-tempo
# New layout: RPC in TEMPO_HOME/rpc, Validator in TEMPO_HOME/validator.
# Ports: https://docs.tempo.xyz/guide/node/system-requirements#ports

# --- Network / node ---
# Chain: moderato (testnet) or mainnet
CHAIN=moderato
# Node home directory (default: $HOME/tempo)
# TEMPO_HOME=$HOME/tempo
# Optional overrides (defaults: $TEMPO_HOME/data, $TEMPO_HOME/keys)
# DATADIR=
# KEYDIR=

# --- Ports (Tempo docs) ---
# | Port  | Protocol | Purpose       | Expose          |
# | 30303 | TCP/UDP  | Execution P2P | Public          |
# | 8000  | TCP      | Consensus P2P | Validators only |
# | 8545  | TCP      | HTTP RPC      | Optional        |
# | 8546  | TCP      | WebSocket RPC | Optional        |
# | 9000  | TCP      | Metrics       | Internal        |
#
# By default RPC and Validator use the same ports above. Override in .env when
# running both on one machine (e.g. VALIDATOR_HTTP_PORT=8547, VALIDATOR_P2P_PORT=30304).
HTTP_ADDR=0.0.0.0
DISCOVERY_ADDR=0.0.0.0

# RPC node (defaults: 8545, 8546, 30303, 9000)
RPC_HTTP_PORT=8545
RPC_WS_PORT=8546
RPC_P2P_PORT=30303
RPC_DISCOVERY_PORT=30303
RPC_METRICS_PORT=9000

# Validator node (defaults: same as docs — 8545, 8546, 30303, 8000, 9000)
VALIDATOR_HTTP_PORT=8545
VALIDATOR_WS_PORT=8546
VALIDATOR_P2P_PORT=30303
VALIDATOR_CONSENSUS_PORT=8000
VALIDATOR_DISCOVERY_PORT=30303
VALIDATOR_METRICS_PORT=9000

# --- Docker ---
# Default image tag
TEMPO_IMAGE=ghcr.io/tempoxyz/tempo:1.1.4
CONTAINER_NAME=tempo

# --- Snapshots API ---
# SNAPSHOTS_API=https://snapshots.tempoxyz.dev/api/snapshots

# --- Telegram (optional) ---
# Create bot via @BotFather, get token. Chat ID: use @userinfobot or getUpdates
# TG_BOT_TOKEN=
# TG_CHAT_ID=

# --- Installer update (optional) ---
# SCRIPT_URL=
